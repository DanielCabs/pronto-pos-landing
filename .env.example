# Copiá este archivo como .env (nunca subas .env a GitHub)
# Agregá estas variables en Vercel → Project Settings → Environment Variables

# Tu API key de Groq (obtené una en console.groq.com)
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXX

# Tu número de WhatsApp con código de país (sin + ni espacios)
# Ejemplo Argentina San Juan: 5492646XXXXXXX
WHATSAPP_NUMBER=5492644XXXXXXX
